---
import { t } from "@lib/i18n.js";
import type { Lang } from "@lib/i18n.js";

interface Props {
  lang?: Lang;
}

const { lang = "tr" } = Astro.props;
const currentPath = Astro.url.pathname;
const tx = t(lang);

const navItems = [
  { key: "work", href: "/work" },
  { key: "notes", href: "/notes" },
  { key: "systems", href: "/systems" },
  { key: "about", href: "/about" },
  { key: "contact", href: "/contact" },
] as const;
---

<nav class="mobile-nav" aria-label={tx.mobileNav.ariaLabel}>
  <button
    class="mobile-toggle"
    aria-expanded="false"
    aria-controls="mobile-menu"
    data-mobile-toggle
  >
    {tx.mobileNav.menu}
  </button>
  <ul class="mobile-list" id="mobile-menu" data-mobile-menu hidden>
    {
      navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class={currentPath.startsWith(item.href) ? "active" : ""}
            aria-current={currentPath.startsWith(item.href) ? "page" : undefined}
          >
            {tx.nav[item.key]}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script>
  const toggle = document.querySelector("[data-mobile-toggle]") as HTMLButtonElement | null;
  const menu = document.querySelector("[data-mobile-menu]") as HTMLElement | null;
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      menu.hidden = expanded;
    });
  }
</script>

<style>
  .mobile-nav {
    display: none;
  }

  @media (max-width: 639px) {
    .mobile-nav {
      display: block;
    }
  }

  .mobile-toggle {
    font-size: var(--type-small);
    line-height: var(--line-small);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    background: none;
    border: none;
    padding: var(--space-1) 0;
    cursor: pointer;
    transition: opacity var(--duration-fast) ease-out;
  }

  .mobile-toggle:hover {
    opacity: 0.65;
  }

  .mobile-list {
    list-style: none;
    position: absolute;
    top: var(--header-height);
    left: 0;
    right: 0;
    background-color: var(--color-background-translucent);
    backdrop-filter: blur(8px);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-list[hidden] {
    display: none;
  }

  .mobile-list a {
    font-size: var(--type-body);
    line-height: var(--line-body);
    font-weight: var(--weight-medium);
    text-decoration: none;
    color: var(--color-text);
    transition: opacity var(--duration-fast) ease-out;
  }

  .mobile-list a:hover {
    opacity: 0.65;
  }

  .mobile-list a.active {
    color: var(--color-text);
  }
</style>
