---
import NavItem from "./NavItem.astro";
import { t } from "@lib/i18n.js";
import type { Lang } from "@lib/i18n.js";

interface Props {
  lang?: Lang;
}

const { lang = "tr" } = Astro.props;
const currentPath = Astro.url.pathname;
const tx = t(lang);

const navItems = [
  { key: "work", href: "/work" },
  { key: "notes", href: "/notes" },
  { key: "systems", href: "/systems" },
  { key: "about", href: "/about" },
  { key: "contact", href: "/contact" },
] as const;
---

<nav aria-label={tx.a11y.primaryNav} class="primary-nav">
  <ul class="nav-list">
    {
      navItems.map((item) => (
        <li>
          <NavItem
            href={item.href}
            label={tx.nav[item.key]}
            isActive={currentPath.startsWith(item.href)}
          />
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .primary-nav {
    display: block;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    list-style: none;
  }

  @media (max-width: 639px) {
    .primary-nav {
      display: none;
    }
  }
</style>
