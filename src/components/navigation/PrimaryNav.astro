---
import NavItem from "./NavItem.astro";
import { siteConfig } from "@lib/siteConfig.js";

const currentPath = Astro.url.pathname;
const navItems = siteConfig.navigation.filter((item) => item.href !== "/");
---

<nav aria-label="Primary" class="primary-nav">
  <ul class="nav-list">
    {
      navItems.map((item) => (
        <li>
          <NavItem
            href={item.href}
            label={item.label}
            isActive={currentPath.startsWith(item.href)}
          />
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .primary-nav {
    display: block;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    list-style: none;
  }

  @media (max-width: 639px) {
    .primary-nav {
      display: none;
    }
  }
</style>
