---
interface Props {
  href: string;
  label: string;
  isActive: boolean;
}

const { href, label, isActive } = Astro.props;
---

<a href={href} class={isActive ? "nav-item active" : "nav-item"} aria-current={isActive ? "page" : undefined}>
  {label}
</a>

<style>
  .nav-item {
    font-size: var(--type-small);
    font-weight: 500;
    text-decoration: none;
    color: var(--color-text-muted);
    letter-spacing: 0.01em;
    transition: color var(--duration-fast) ease-out;
    padding: var(--space-1) 0;
  }

  .nav-item:hover {
    color: var(--color-text);
  }

  .nav-item.active {
    color: var(--color-text);
  }
</style>
