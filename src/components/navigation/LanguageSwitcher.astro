---
import { languages, langNames, defaultLang, t } from "@lib/i18n.js";
import type { Lang } from "@lib/i18n.js";

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const tx = t(lang);
const currentPath = Astro.url.pathname;

function getNeutralPath(path: string): string {
  for (const l of languages) {
    if (l === defaultLang) continue;
    const prefix = `/${l}`;
    if (path === prefix) return "/";
    if (path.startsWith(`${prefix}/`)) return path.slice(prefix.length) || "/";
  }
  return path;
}

function getLangPath(targetLang: Lang, neutralPath: string): string {
  if (targetLang === defaultLang) return neutralPath;
  if (neutralPath === "/") return `/${targetLang}`;
  return `/${targetLang}${neutralPath}`;
}

const neutralPath = getNeutralPath(currentPath);
---

<nav class="lang-segmented" aria-label={tx.a11y.language}>
  {languages.map((l) => {
    const href = getLangPath(l, neutralPath);
    const isActive = l === lang;
    return (
      <a
        href={href}
        class={isActive ? "lang-seg active" : "lang-seg"}
        hreflang={l}
        aria-current={isActive ? "true" : undefined}
      >
        {langNames[l]}
      </a>
    );
  })}
</nav>

<style>
  .lang-segmented {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background-color: var(--color-surface);
    overflow: hidden;
  }

  .lang-seg {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5px 10px;
    font-size: 12px;
    line-height: 1;
    font-weight: var(--weight-semibold);
    text-decoration: none;
    color: var(--color-text-muted);
    transition: background-color var(--duration-fast) ease-out, color var(--duration-fast) ease-out;
    white-space: nowrap;
  }

  .lang-seg:hover {
    color: var(--color-text);
  }

  .lang-seg:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
    position: relative;
    z-index: 1;
  }

  .lang-seg.active {
    background-color: var(--color-text);
    color: var(--color-surface);
  }

  @media (max-width: 639px) {
    .lang-seg {
      padding: 4px 8px;
      font-size: 11px;
    }
  }

  @media (max-width: 374px) {
    .lang-seg {
      padding: 3px 6px;
      font-size: 10px;
    }
  }
</style>
