---
import { siteConfig } from "@lib/siteConfig.js";
import type { Lang } from "@lib/i18n.js";
import { langDirs, languages, defaultLang } from "@lib/i18n.js";

interface Props {
  title: string;
  description?: string | undefined;
  canonicalPath?: string | undefined;
  lang?: Lang;
}

const {
  title,
  description = siteConfig.description,
  canonicalPath = "",
  lang = "tr",
} = Astro.props;
const canonicalUrl = canonicalPath === "/" ? siteConfig.url : `${siteConfig.url}${canonicalPath}`;
const dir = langDirs[lang];

function getNeutralPath(path: string): string {
  for (const l of languages) {
    if (l === defaultLang) continue;
    const prefix = `/${l}`;
    if (path === prefix) return "/";
    if (path.startsWith(`${prefix}/`)) return path.slice(prefix.length) || "/";
  }
  return path;
}

function getLangPath(targetLang: Lang, neutralPath: string): string {
  if (targetLang === defaultLang) return neutralPath;
  if (neutralPath === "/") return `/${targetLang}`;
  return `/${targetLang}${neutralPath}`;
}

const neutralPath = getNeutralPath(canonicalPath);
const isHome = neutralPath === "/" || neutralPath === "";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Arda Deniz Çolak",
  jobTitle: "Otomasyon Entegrasyonu, Web Site Geliştirme ve Yazılım Çözümleri Uzmanı",
  email: "adclk06@gmail.com",
  telephone: "+90 544 525 70 40",
  url: siteConfig.url,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Çekmeköy",
    addressRegion: "İstanbul",
    addressCountry: "TR",
  },
};

const professionalServiceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "Arda Deniz Çolak",
  image: `${siteConfig.url}/favicon.svg`,
  url: siteConfig.url,
  email: "adclk06@gmail.com",
  telephone: "+90 544 525 70 40",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Çekmeköy",
    addressRegion: "İstanbul",
    addressCountry: "TR",
  },
  areaServed: ["İstanbul", "Çekmeköy", "Türkiye"],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Hizmetler",
    itemListElement: [
      "Web Site Yapımı",
      "Otomasyon Entegrasyonu",
      "Yazılım Çözümleri",
      "Özel Yazılım Geliştirme",
      "Kurumsal Web Sitesi",
    ].map((service) => ({
      "@type": "Offer",
      itemOffered: { "@type": "Service", name: service },
    })),
  },
};
---

<!DOCTYPE html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    {languages.map((l) => {
      const langPath = getLangPath(l, neutralPath);
      const href = langPath === "/" ? siteConfig.url : `${siteConfig.url}${langPath}`;
      return <link rel="alternate" hreflang={l} href={href} />;
    })}
    <link rel="alternate" hreflang="x-default" href={neutralPath === "/" ? siteConfig.url : `${siteConfig.url}${neutralPath}`} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.name} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    {isHome && (
      <script type="application/ld+json" set:html={JSON.stringify(professionalServiceSchema)} />
    )}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      @import "@styles/tokens.css";
      @import "@styles/reset.css";
      @import "@styles/base.css";
      @import "@styles/layout.css";
      @import "@styles/motion.css";
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
