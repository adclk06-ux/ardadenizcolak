---
import { siteConfig } from "@lib/siteConfig.js";
import type { Lang } from "@lib/i18n.js";
import { langDirs, languages, defaultLang } from "@lib/i18n.js";

interface Props {
  title: string;
  description?: string | undefined;
  canonicalPath?: string | undefined;
  lang?: Lang;
}

const {
  title,
  description = siteConfig.description,
  canonicalPath = "",
  lang = "tr",
} = Astro.props;
const canonicalUrl = `${siteConfig.url}${canonicalPath}`;
const dir = langDirs[lang];

function getNeutralPath(path: string): string {
  for (const l of languages) {
    if (l === defaultLang) continue;
    const prefix = `/${l}`;
    if (path === prefix) return "/";
    if (path.startsWith(`${prefix}/`)) return path.slice(prefix.length) || "/";
  }
  return path;
}

function getLangPath(targetLang: Lang, neutralPath: string): string {
  if (targetLang === defaultLang) return neutralPath;
  if (neutralPath === "/") return `/${targetLang}`;
  return `/${targetLang}${neutralPath}`;
}

const neutralPath = getNeutralPath(canonicalPath);
---

<!DOCTYPE html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    {languages.map((l) => {
      const href = `${siteConfig.url}${getLangPath(l, neutralPath)}`;
      return <link rel="alternate" hreflang={l} href={href} />;
    })}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.name} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      @import "@styles/tokens.css";
      @import "@styles/reset.css";
      @import "@styles/base.css";
      @import "@styles/layout.css";
      @import "@styles/motion.css";
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
