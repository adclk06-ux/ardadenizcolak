---
export interface Props {
  as?: "code" | "span" | "pre";
}

const { as: Tag = "code" } = Astro.props;
---

<Tag class="mono">
  <slot />
</Tag>

<style>
  .mono {
    font-family: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, Consolas, monospace;
    font-size: var(--type-mono);
    line-height: var(--line-mono);
  }
</style>
