---
export interface Props {
  as?: "h1" | "h2" | "h3";
}

const { as: Tag = "h1" } = Astro.props;
---

<Tag class="display">
  <slot />
</Tag>

<style>
  .display {
    font-size: var(--type-display);
    line-height: var(--line-display);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--color-text);
  }
</style>
