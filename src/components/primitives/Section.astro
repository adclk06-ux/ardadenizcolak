---
interface Props {
  class?: string;
  padding?: "none" | "sm" | "md" | "lg" | "xl";
}

const { class: className = "", padding = "md" } = Astro.props;

const paddingMap = {
  none: "0",
  sm: "var(--space-4)",
  md: "var(--space-6)",
  lg: "var(--space-8)",
  xl: "var(--space-10)",
};
---

<section class={`section ${className}`} style={`padding-block: ${paddingMap[padding]};`}>
  <slot />
</section>

<style>
  .section {
    width: 100%;
  }
</style>
