---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class={`container ${className}`}>
  <slot />
</div>

<style>
  .container {
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-4);
  }

  @media (min-width: 640px) {
    .container {
      padding-inline: var(--space-6);
    }
  }
</style>
