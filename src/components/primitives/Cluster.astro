---
interface Props {
  class?: string;
  gap?: "1" | "2" | "3" | "4" | "5" | "6" | "7" | "8";
  justify?: "start" | "center" | "end" | "between";
  align?: "start" | "center" | "end" | "baseline";
}

const { class: className = "", gap = "4", justify = "start", align = "center" } = Astro.props;

const gapMap = {
  "1": "var(--space-1)",
  "2": "var(--space-2)",
  "3": "var(--space-3)",
  "4": "var(--space-4)",
  "5": "var(--space-5)",
  "6": "var(--space-6)",
  "7": "var(--space-7)",
  "8": "var(--space-8)",
};

const justifyMap = {
  start: "flex-start",
  center: "center",
  end: "flex-end",
  between: "space-between",
};
---

<div
  class={`cluster ${className}`}
  style={`gap: ${gapMap[gap]}; justify-content: ${justifyMap[justify]}; align-items: ${align};`}
>
  <slot />
</div>

<style>
  .cluster {
    display: flex;
    flex-wrap: wrap;
  }
</style>
