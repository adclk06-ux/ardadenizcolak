---
interface Props {
  class?: string;
  columns?: "1" | "2" | "3" | "4";
  gap?: "1" | "2" | "3" | "4" | "5" | "6" | "8";
}

const {
  class: className = "",
  columns = "1",
  gap = "6",
} = Astro.props;

const gapMap = {
  "1": "var(--space-1)",
  "2": "var(--space-2)",
  "3": "var(--space-3)",
  "4": "var(--space-4)",
  "5": "var(--space-5)",
  "6": "var(--space-6)",
  "8": "var(--space-8)",
};
---

<div
  class={`grid ${className}`}
  style={`gap: ${gapMap[gap]}; grid-template-columns: repeat(${columns}, minmax(0, 1fr));`}
>
  <slot />
</div>

<style>
  .grid {
    display: grid;
  }

  @media (max-width: 639px) {
    .grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
