---
import type { Lang } from "@lib/i18n.js";
import { t } from "@lib/i18n.js";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tx = t(lang);
const accessKey = import.meta.env.PUBLIC_CONTACT_FORM_ACCESS_KEY ?? "";
---

<form
  class="contact-form"
  data-contact-form
  data-tx-required={tx.form.required}
  data-tx-invalid-email={tx.form.invalidEmail}
  data-tx-sending={tx.form.sending}
  data-tx-submit={tx.form.submit}
  data-tx-success={tx.form.success}
  data-tx-error={tx.form.error}
  action="https://api.web3forms.com/submit"
  method="POST"
  novalidate
>
  <input type="hidden" name="access_key" value={accessKey} />
  <input type="hidden" name="from_name" value="Arda Deniz Çolak Portfolio" />
  <input type="text" name="botcheck" class="honeypot" tabindex="-1" autocomplete="off" />

  <div class="form-group">
    <label for="contact-name">{tx.form.name}</label>
    <input
      type="text"
      id="contact-name"
      name="name"
      required
      autocomplete="name"
    />
    <span class="error-msg" data-error-for="name"></span>
  </div>

  <div class="form-group">
    <label for="contact-email">{tx.form.email}</label>
    <input
      type="email"
      id="contact-email"
      name="email"
      required
      autocomplete="email"
    />
    <span class="error-msg" data-error-for="email"></span>
  </div>

  <div class="form-group">
    <label for="contact-subject">{tx.form.subject}</label>
    <input
      type="text"
      id="contact-subject"
      name="subject"
      required
    />
    <span class="error-msg" data-error-for="subject"></span>
  </div>

  <div class="form-group">
    <label for="contact-message">{tx.form.message}</label>
    <textarea
      id="contact-message"
      name="message"
      rows="5"
      required
    ></textarea>
    <span class="error-msg" data-error-for="message"></span>
  </div>

  <button type="submit" class="submit-btn" data-submit-btn>
    {tx.form.submit}
  </button>

  <p class="form-status" data-form-status role="status" aria-live="polite"></p>
</form>

<script>
  const forms = document.querySelectorAll("[data-contact-form]");

  forms.forEach((form) => {
    const submitBtn = form.querySelector("[data-submit-btn]") as HTMLButtonElement;
    const statusEl = form.querySelector("[data-form-status]") as HTMLElement;
    const accessKeyInput = form.querySelector('input[name="access_key"]') as HTMLInputElement;

    const isDev = location.hostname === "localhost" || location.hostname === "127.0.0.1";
    if (!accessKeyInput?.value && isDev) {
      console.warn("[ContactForm] PUBLIC_CONTACT_FORM_ACCESS_KEY is not set. Form submissions will fail.");
    }

    const tx = {
      required: (form as HTMLElement).dataset.txRequired || "This field is required.",
      invalidEmail: (form as HTMLElement).dataset.txInvalidEmail || "Please enter a valid email address.",
      sending: (form as HTMLElement).dataset.txSending || "Sending...",
      submit: (form as HTMLElement).dataset.txSubmit || "Send",
      success: (form as HTMLElement).dataset.txSuccess || "Your message has been sent successfully.",
      error: (form as HTMLElement).dataset.txError || "The message could not be sent. Please try again.",
    };

    function showError(field: HTMLInputElement | HTMLTextAreaElement, msg: string) {
      const errEl = form.querySelector(`[data-error-for="${field.name}"]`);
      if (errEl) errEl.textContent = msg;
      field.setAttribute("aria-invalid", "true");
    }

    function clearErrors() {
      form.querySelectorAll("[data-error-for]").forEach((el) => {
        el.textContent = "";
      });
      form.querySelectorAll("input, textarea").forEach((el) => {
        (el as HTMLElement).removeAttribute("aria-invalid");
      });
    }

    function validate(): boolean {
      clearErrors();
      let ok = true;
      const fields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>("input[name], textarea[name]");
      fields.forEach((field) => {
        if (field.name === "botcheck" || field.name === "access_key" || field.name === "from_name") return;
        if (!field.value.trim()) {
          showError(field, tx.required);
          ok = false;
        } else if (field.type === "email" && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value)) {
          showError(field, tx.invalidEmail);
          ok = false;
        }
      });
      return ok;
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!validate()) return;

      const originalText = submitBtn.textContent || "";
      submitBtn.disabled = true;
      submitBtn.textContent = tx.sending;
      statusEl.textContent = "";
      statusEl.className = "form-status";

      try {
        const data = new FormData(form as HTMLFormElement);
        const res = await fetch((form as HTMLFormElement).action, {
          method: "POST",
          body: data,
        });
        const json = await res.json();
        if (json.success) {
          statusEl.textContent = tx.success;
          statusEl.classList.add("success");
          (form as HTMLFormElement).reset();
        } else {
          throw new Error(json.message || "Failed");
        }
      } catch {
        statusEl.textContent = tx.error;
        statusEl.classList.add("error");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  });
</script>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: var(--color-surface);
  }

  .honeypot {
    position: absolute;
    left: -9999px;
    opacity: 0;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .form-group label {
    font-size: var(--type-small);
    line-height: var(--line-small);
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  .form-group input,
  .form-group textarea {
    font-family: var(--font-sans);
    font-size: var(--type-body);
    line-height: var(--line-body);
    color: var(--color-text);
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-3);
    transition: border-color var(--duration-fast) ease-out;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .form-group input[aria-invalid="true"],
  .form-group textarea[aria-invalid="true"] {
    border-color: var(--color-trust);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .error-msg {
    font-size: var(--type-small);
    line-height: var(--line-small);
    color: var(--color-trust);
    min-height: 1.4em;
  }

  .submit-btn {
    align-self: flex-start;
    font-family: var(--font-sans);
    font-size: var(--type-body);
    line-height: var(--line-body);
    font-weight: var(--weight-medium);
    color: var(--color-surface);
    background-color: var(--color-text);
    border: none;
    border-radius: var(--radius-pill);
    padding: var(--space-2) var(--space-5);
    cursor: pointer;
    transition: opacity var(--duration-fast) ease-out;
  }

  .submit-btn:hover:not(:disabled) {
    opacity: 0.85;
  }

  .submit-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .form-status {
    font-size: var(--type-body);
    line-height: var(--line-body);
    min-height: 1.6em;
  }

  .form-status.success {
    color: var(--color-accent);
  }

  .form-status.error {
    color: var(--color-trust);
  }
</style>
