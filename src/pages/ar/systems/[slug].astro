---
import { type CollectionEntry, getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import Prose from "@components/typography/Prose.astro";
import { t } from "@lib/i18n.js";
import { localizedTitle } from "@lib/contentI18n.js";

export async function getStaticPaths() {
  const entries = await getCollection("systems");
  return entries.map((entry: CollectionEntry<"systems">) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<"systems">;
};

const { entry } = Astro.props;
const { Content } = await entry.render();
const lang = "ar";
const tx = t(lang);
---

<Base title={localizedTitle(lang, "systems", entry.slug, entry.data.title)} lang={lang}>
  <article class="system-article">
    <header class="system-header">
      <div class="system-meta">
        <span class="system-category">{tx.maps.category[entry.data.category] ?? entry.data.category}</span>
        <span class="system-complexity">{tx.maps.complexity[entry.data.complexity] ?? entry.data.complexity}</span>
      </div>
      <h1>{localizedTitle(lang, "systems", entry.slug, entry.data.title)}</h1>
    </header>
    <Prose>
      <Content />
    </Prose>
  </article>
</Base>

<style>
  .system-article {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-5);
    padding-block: var(--space-7);
  }

  .system-header {
    margin-bottom: var(--space-7);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--color-border);
  }

  .system-meta {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .system-category {
    font-size: var(--type-small);
    line-height: var(--line-small);
    font-weight: var(--weight-medium);
    color: var(--color-accent);
  }

  .system-complexity {
    font-size: var(--type-small);
    line-height: var(--line-small);
    color: var(--color-text-muted);
    text-transform: capitalize;
  }

  .system-header h1 {
    font-size: var(--type-display);
    line-height: var(--line-display);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }
</style>
