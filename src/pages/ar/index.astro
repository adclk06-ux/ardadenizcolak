---
import Base from "@layouts/Base.astro";
import { t } from "@lib/i18n.js";

const lang = "ar";
const tx = t(lang);
---

<Base title="Arda Deniz Çolak" description={tx.meta.description} lang={lang}>
  <section class="hero">
    <p class="eyebrow">{tx.home.eyebrow}</p>
    <h1 class="headline">{tx.home.headline}</h1>
    <p class="description">{tx.home.description}</p>
    <a href="/ar/work" class="cta">{tx.home.cta} <span aria-hidden="true">→</span></a>
  </section>
</Base>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-5);
    min-height: calc(100vh - var(--header-height));
    padding-inline: var(--space-5);
    padding-block: var(--space-7);
    max-width: var(--max-width);
    margin-inline: auto;
    width: 100%;
  }

  .eyebrow {
    font-size: var(--type-small);
    line-height: var(--line-small);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .headline {
    font-size: var(--type-display);
    line-height: var(--line-display);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    max-width: var(--measure-prose);
  }

  .description {
    font-size: var(--type-body);
    line-height: var(--line-body);
    color: var(--color-text-muted);
    max-width: var(--measure-body);
  }

  .cta {
    font-size: var(--type-body);
    line-height: var(--line-body);
    font-weight: var(--weight-medium);
    text-decoration: none;
    color: var(--color-accent);
    transition: color var(--duration-fast) ease-out;
    margin-top: var(--space-2);
  }

  .cta:hover {
    color: var(--color-accent-hover);
  }

  @media (max-width: 639px) {
    .hero {
      gap: var(--space-4);
    }

    .headline {
      font-size: var(--type-section);
      line-height: var(--line-section);
    }
  }
</style>
