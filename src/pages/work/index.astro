---
import Base from "@layouts/Base.astro";
import { getPublishedWork } from "@lib/content.js";
import { t } from "@lib/i18n.js";

const entries = await getPublishedWork();
const lang = "tr";
const tx = t(lang);
---

<Base title={tx.work.title} lang={lang}>
  <div class="work-index">
    <header>
      <h1>{tx.work.title}</h1>
      <p class="subtitle">{tx.work.subtitle}</p>
    </header>

    <ul class="project-list">
      {
        entries.map((entry) => (
          <li class="project-item">
            <a href={`/work/${entry.slug}`} class="project-link">
              <div class="project-meta">
                <span class="project-year">{entry.data.year}</span>
                <span class="project-status">{tx.maps.status[entry.data.status] ?? entry.data.status}</span>
              </div>
              <h2 class="project-title">{entry.data.title}</h2>
              <p class="project-summary">{entry.data.summary}</p>
              <div class="project-tech">
                {entry.data.technologies.map((tech: string) => (
                  <span class="tech-tag">{tech}</span>
                ))}
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Base>

<style>
  .work-index {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-5);
    padding-block: var(--space-7);
  }

  header {
    margin-bottom: var(--space-7);
  }

  h1 {
    font-size: var(--type-display);
    line-height: var(--line-display);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .subtitle {
    font-size: var(--type-body);
    line-height: var(--line-body);
    color: var(--color-text-muted);
    margin-top: var(--space-3);
  }

  .project-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .project-item {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-5);
  }

  .project-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .project-link:hover .project-title {
    color: var(--color-accent);
  }

  .project-meta {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .project-year {
    font-size: var(--type-small);
    line-height: var(--line-small);
    color: var(--color-text-muted);
  }

  .project-status {
    font-size: var(--type-small);
    line-height: var(--line-small);
    color: var(--color-accent);
  }

  .project-title {
    font-size: var(--type-section);
    line-height: var(--line-section);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    transition: color var(--duration-fast) ease-out;
  }

  .project-summary {
    font-size: var(--type-body);
    line-height: var(--line-body);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
    max-width: var(--measure-body);
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }

  .tech-tag {
    font-size: var(--type-small);
    line-height: var(--line-small);
    color: var(--color-text-muted);
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }
</style>
