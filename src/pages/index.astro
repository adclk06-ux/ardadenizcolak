---
import Base from "@layouts/Base.astro";
import { siteConfig } from "@lib/siteConfig.js";
---

<Base title={siteConfig.name} description={siteConfig.description}>
  <section class="hero">
    <h1 class="name">{siteConfig.name}</h1>
    <p class="position">{siteConfig.tagline}</p>
    <ul class="philosophy">
      {siteConfig.philosophy.map((sentence) => (
        <li>{sentence}</li>
      ))}
    </ul>
  </section>
</Base>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-6);
    min-height: calc(100vh - var(--header-height));
    padding-inline: var(--space-5);
    padding-block: var(--space-7);
    max-width: var(--max-width);
    margin-inline: auto;
    width: 100%;
  }

  .name {
    font-size: var(--type-display);
    line-height: var(--line-display);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .position {
    font-size: var(--type-hero);
    line-height: var(--line-hero);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    max-width: var(--measure-prose);
  }

  .philosophy {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .philosophy li {
    font-size: var(--type-body);
    line-height: var(--line-body);
    color: var(--color-text-muted);
    max-width: var(--measure-body);
  }

  @media (max-width: 639px) {
    .hero {
      gap: var(--space-5);
    }

    .position {
      font-size: var(--type-section);
      line-height: var(--line-section);
    }
  }
</style>
