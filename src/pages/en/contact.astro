---
import Base from "@layouts/Base.astro";
import ContactForm from "@components/ContactForm.astro";
import { t } from "@lib/i18n.js";

const lang = "en";
const tx = t(lang);
---

<Base title={tx.contact.title} lang={lang}>
  <div class="contact-page">
    <header>
      <h1>{tx.contact.title}</h1>
    </header>

    <section class="contact-section">
      <h2>{tx.contact.fullName}</h2>
      <p class="contact-value">Arda Deniz Çolak</p>
    </section>

    <section class="contact-section">
      <h2>{tx.contact.email}</h2>
      <p class="contact-value">
        <a href="mailto:adclk06@gmail.com">adclk06@gmail.com</a>
      </p>
    </section>

    <section class="contact-section">
      <h2>{tx.contact.phone}</h2>
      <p class="contact-value">
        <a href="tel:+905445257040">+90 544 525 70 40</a>
      </p>
    </section>

    <section class="contact-section">
      <h2>{tx.contact.whatsapp}</h2>
      <p class="contact-value">
        <a href="https://wa.me/905445257040" target="_blank" rel="noopener">+90 544 525 70 40</a>
      </p>
    </section>

    <section class="contact-section">
      <h2>{tx.contact.location}</h2>
      <p class="contact-value">{tx.contact.locationText}</p>
    </section>

    <section class="contact-section">
      <h2>{tx.contact.availability}</h2>
      <p class="contact-value">{tx.contact.availabilityText}</p>
    </section>

    <section class="contact-section form-section">
      <h2>{tx.form.submit}</h2>
      <ContactForm lang={lang} />
    </section>

    <section class="contact-section">
      <h2>{tx.contact.inquiryTypesLabel}</h2>
      <ul class="inquiry-list">
        {tx.contact.inquiryTypes.map((type) => (
          <li>{type}</li>
        ))}
      </ul>
    </section>

    <section class="contact-section">
      <h2>{tx.contact.whatToInclude}</h2>
      <p>{tx.contact.whatToIncludeText}</p>
    </section>

    <section class="contact-section">
      <h2>{tx.contact.responseTimeLabel}</h2>
      <p>{tx.contact.responseTime}</p>
    </section>

    <section class="contact-section">
      <h2>{tx.contact.notWelcomeLabel}</h2>
      <ul class="not-welcome-list">
        {tx.contact.notWelcome.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>
  </div>
</Base>

<style>
  .contact-page {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-5);
    padding-block: var(--space-7);
  }

  header {
    margin-bottom: var(--space-7);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--color-border);
  }

  h1 {
    font-size: var(--type-display);
    line-height: var(--line-display);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .contact-section {
    margin-bottom: var(--space-6);
  }

  .contact-section h2 {
    font-size: var(--type-section);
    line-height: var(--line-section);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .contact-section p {
    font-size: var(--type-body);
    line-height: var(--line-body);
    color: var(--color-text-muted);
    max-width: var(--measure-prose);
  }

  .contact-value {
    font-size: var(--type-body);
    line-height: var(--line-body);
    color: var(--color-text-muted);
    max-width: var(--measure-prose);
  }

  .contact-value a {
    font-weight: var(--weight-medium);
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--duration-fast) ease-out;
  }

  .contact-value a:hover {
    color: var(--color-accent-hover);
  }

  .inquiry-list,
  .not-welcome-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .inquiry-list li,
  .not-welcome-list li {
    font-size: var(--type-body);
    line-height: var(--line-body);
    color: var(--color-text-muted);
    max-width: var(--measure-prose);
  }
</style>
