---
import Base from "@layouts/Base.astro";
import { t } from "@lib/i18n.js";

const lang = "en";
const tx = t(lang);
---

<Base title={tx.about.title} lang={lang}>
  <div class="about-page">
    <header>
      <h1>{tx.about.title}</h1>
    </header>

    <section class="about-section">
      <h2>{tx.about.principles}</h2>
      <div class="about-grid">
        {tx.about.principlesList.map((item) => (
          <article class="about-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="about-section">
      <h2>{tx.about.currentFocus}</h2>
      <p>{tx.about.currentFocusText}</p>
    </section>

    <section class="about-section">
      <h2>{tx.about.workingStyle}</h2>
      <div class="about-grid">
        {tx.about.workingStyleList.map((item) => (
          <article class="about-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="about-section">
      <h2>{tx.about.background}</h2>
      <div class="about-grid">
        {tx.about.backgroundList.map((item) => (
          <article class="about-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>
  </div>
</Base>

<style>
  .about-page {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-5);
    padding-block: var(--space-7);
  }

  header {
    margin-bottom: var(--space-7);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--color-border);
  }

  h1 {
    font-size: var(--type-display);
    line-height: var(--line-display);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .about-section {
    margin-bottom: var(--space-7);
  }

  .about-section h2 {
    font-size: var(--type-section);
    line-height: var(--line-section);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .about-section p {
    font-size: var(--type-body);
    line-height: var(--line-body);
    color: var(--color-text-muted);
    max-width: var(--measure-prose);
  }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .about-card {
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: var(--color-surface);
  }

  .about-card h3 {
    font-size: var(--type-body);
    line-height: var(--line-body);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .about-card p {
    font-size: var(--type-small);
    line-height: var(--line-body);
    color: var(--color-text-muted);
    max-width: none;
  }
</style>
