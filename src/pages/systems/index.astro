---
import Base from "@layouts/Base.astro";
import { getPublishedSystems } from "@lib/content.js";

const entries = await getPublishedSystems();
---

<Base title="Systems">
  <div class="systems-index">
    <header>
      <h1>Systems</h1>
      <p class="subtitle">Infrastructure, automation, and operational decisions.</p>
    </header>

    <ul class="system-list">
      {
        entries.map((entry) => (
          <li class="system-item">
            <a href={`/systems/${entry.slug}`} class="system-link">
              <div class="system-meta">
                <span class="system-category">{entry.data.category}</span>
                <span class="system-complexity">{entry.data.complexity}</span>
              </div>
              <h2 class="system-title">{entry.data.title}</h2>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Base>

<style>
  .systems-index {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-5);
    padding-block: var(--space-7);
  }

  header {
    margin-bottom: var(--space-7);
  }

  h1 {
    font-size: var(--type-display);
    line-height: var(--line-display);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .subtitle {
    font-size: var(--type-body);
    line-height: var(--line-body);
    color: var(--color-text-muted);
    margin-top: var(--space-3);
  }

  .system-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .system-item {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-5);
  }

  .system-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .system-link:hover .system-title {
    color: var(--color-accent);
  }

  .system-meta {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .system-category {
    font-size: var(--type-small);
    line-height: var(--line-small);
    color: var(--color-accent);
  }

  .system-complexity {
    font-size: var(--type-small);
    line-height: var(--line-small);
    color: var(--color-text-muted);
    text-transform: capitalize;
  }

  .system-title {
    font-size: var(--type-section);
    line-height: var(--line-section);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    transition: color var(--duration-fast) ease-out;
  }
</style>
