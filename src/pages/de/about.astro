---
import Base from "@layouts/Base.astro";
import { t } from "@lib/i18n.js";

const lang = "de";
const tx = t(lang);
---

<Base title={tx.about.title} lang={lang}>
  <div class="about-page">
    <header>
      <h1>{tx.about.title}</h1>
    </header>

    <section class="about-section">
      <h2>{tx.about.principles}</h2>
      <ul class="principle-list">
        {tx.about.principlesList.map((principle) => (
          <li>{principle}</li>
        ))}
      </ul>
    </section>

    <section class="about-section">
      <h2>{tx.about.currentFocus}</h2>
      <p>{tx.about.currentFocusText}</p>
    </section>

    <section class="about-section">
      <h2>{tx.about.workingStyle}</h2>
      <p>{tx.about.workingStyleText}</p>
    </section>

    <section class="about-section">
      <h2>{tx.about.tooling}</h2>
      <p>{tx.about.toolingText}</p>
    </section>

    <section class="about-section">
      <h2>{tx.about.outsideWork}</h2>
      <p>{tx.about.outsideWorkText}</p>
    </section>
  </div>
</Base>

<style>
  .about-page {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-5);
    padding-block: var(--space-7);
  }

  header {
    margin-bottom: var(--space-7);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--color-border);
  }

  h1 {
    font-size: var(--type-display);
    line-height: var(--line-display);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .about-section {
    margin-bottom: var(--space-7);
  }

  .about-section h2 {
    font-size: var(--type-section);
    line-height: var(--line-section);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .about-section p {
    font-size: var(--type-body);
    line-height: var(--line-body);
    color: var(--color-text-muted);
    max-width: var(--measure-prose);
  }

  .principle-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .principle-list li {
    font-size: var(--type-body);
    line-height: var(--line-body);
    color: var(--color-text-muted);
    max-width: var(--measure-prose);
  }
</style>
