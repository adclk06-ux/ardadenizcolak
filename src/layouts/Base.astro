---
interface Props {
  title: string;
  description?: string | undefined;
}

const { title, description } = Astro.props;
---

<BaseLayout title={pageTitle(title)} description={description}>
  <div class="site-wrapper">
    <PageHeader />
    <Main>
      <slot />
    </Main>
    <PageFooter />
  </div>
</BaseLayout>

<style>
  .site-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
</style>
