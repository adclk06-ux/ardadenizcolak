---
import BaseLayout from "@components/layout/BaseLayout.astro";
import PageHeader from "@components/layout/PageHeader.astro";
import PageFooter from "@components/layout/PageFooter.astro";
import Main from "@components/layout/Main.astro";
import { pageTitle } from "@lib/metadata.js";
import type { Lang } from "@lib/i18n.js";

interface Props {
  title: string;
  description?: string | undefined;
  lang?: Lang;
}

const { title, description, lang = "tr" } = Astro.props;
const canonicalPath = Astro.url.pathname;
---

<BaseLayout title={pageTitle(title)} description={description} canonicalPath={canonicalPath} lang={lang}>
  <div class="site-wrapper">
    <PageHeader lang={lang} />
    <Main>
      <slot />
    </Main>
    <PageFooter lang={lang} />
  </div>
</BaseLayout>

<style>
  .site-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
</style>
